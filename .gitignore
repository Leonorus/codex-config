# Ignore everything by default. ~/.codex mixes config with auth, logs,
# chat/session history, caches, SQLite state, and temporary runtime files.
*

# Repository metadata/docs.
!.gitignore
!README.md
!AGENTS.md
!RTK.md
!hooks.json
!hooks/
!hooks/*.sh
!requirements-dev.txt

# Codex configuration intended for sync.
!config.toml
!rules/
!rules/**
!skills/
!skills/codex-workflow/
!skills/codex-workflow/SKILL.md
!skills/codex-workflow/agents/
!skills/codex-workflow/agents/openai.yaml
!skills/codex-knowledge/
!skills/codex-knowledge/SKILL.md
!skills/codex-knowledge/agents/
!skills/codex-knowledge/agents/openai.yaml
!version.json
# Split workflow bucket contract skills.
!skills/workflow-*-contract/
!skills/workflow-*-contract/SKILL.md
